<Window x:Class="FastTaskManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:vm="clr-namespace:FastTaskManager.App.ViewModels"
        xmlns:views="clr-namespace:FastTaskManager.App.Views"
        mc:Ignorable="d"
        Title="FastTaskManager"
        Width="1440"
        Height="900"
        MinWidth="1100"
        MinHeight="720"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}"
        WindowState="Maximized"
        FontFamily="Microsoft YaHei"
        AllowsTransparency="False">

    <Window.Resources>
        <tb:TaskbarIcon x:Key="MyNotifyIcon"
                        IconSource="Resources/进程管理.ico"
                        ToolTipText="FastTaskManager">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="显示窗口" Click="ShowWindow_Click" />
                    <MenuItem Header="退出程序" Click="Exit_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style TargetType="Thumb" x:Key="ScrollThumbStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThBorder" Background="{DynamicResource BorderStrongBrush}" CornerRadius="4" Margin="2,1" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThBorder" Property="Background" Value="{DynamicResource Muted2Brush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThBorder" Property="Background" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Width" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root" Background="Transparent">
                            <Border x:Name="TrackBg" Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Opacity="0" />
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Value="{TemplateBinding Value}"
                                   Minimum="{TemplateBinding Minimum}" Maximum="{TemplateBinding Maximum}"
                                   ViewportSize="{TemplateBinding ViewportSize}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"
                                                  IsTabStop="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumbStyle}" Cursor="Hand" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"
                                                  IsTabStop="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="8" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                            <Trigger SourceName="Root" Property="IsMouseOver" Value="True">
                                <Setter TargetName="TrackBg" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" BasedOn="{StaticResource PillButton}" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
        </Style>
        <Style x:Key="TopBarActionButton" BasedOn="{StaticResource PillButton}" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TopBarDangerButton" BasedOn="{StaticResource TopBarActionButton}" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource ErrorTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ErrorBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ErrorBorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource DangerHoverBrush}" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="BorderBrush" Value="{DynamicResource DangerHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource DangerPressedBrush}" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="BorderBrush" Value="{DynamicResource DangerPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WinBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" /><Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource WindowButtonForegroundBrush}" /><Setter Property="Width" Value="46" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource WindowButtonHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource WindowButtonPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseBtnStyle" BasedOn="{StaticResource WinBtnStyle}" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource DangerHoverBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource DangerPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavButtonBase" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        </Style>

        <DataTemplate DataType="{x:Type vm:ProcessesViewModel}">
            <views:ProcessesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PerformanceViewModel}">
            <views:PerformanceView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StartupAppsViewModel}">
            <views:StartupAppsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ServicesViewModel}">
            <views:ServicesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="shell:WindowChrome.WindowChrome">
                <Setter.Value>
                    <shell:WindowChrome CaptionHeight="48" GlassFrameThickness="-1" CornerRadius="0" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Window">
                        <Border x:Name="WindowBorder" Background="{DynamicResource BgBrush}" BorderThickness="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="48" /><RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Background="{DynamicResource BgBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                                Margin="16,0,0,0">
                                        <Border Width="3" Height="16" CornerRadius="1.5"
                                                Background="{DynamicResource AccentBrush}" Margin="0,0,8,0" />
                                        <TextBlock Text="FastTaskManager" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                                        <Border Margin="10,0,0,0" Padding="6,2" Background="{DynamicResource SubtleAccentBrush}"
                                                BorderBrush="{DynamicResource SubtleAccentBorderBrush}" BorderThickness="1" CornerRadius="4"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding CurrentSectionBadgeText}"
                                                       Foreground="{DynamicResource AccentBrush}" FontSize="11"
                                                       FontWeight="Medium" />
                                        </Border>
                                    </StackPanel>
                                    <Border Grid.ColumnSpan="4" HorizontalAlignment="Center"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="7" VerticalAlignment="Center" Height="32" Width="260"
                                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                            Visibility="{Binding IsProcessesPage, Converter={StaticResource BoolToVisibility}}">
                                        <Grid Margin="10,0">
                                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource MutedBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBox Margin="20,0,0,0" Background="Transparent" BorderThickness="0"
                                                     Foreground="{DynamicResource TextBrush}"
                                                     CaretBrush="{DynamicResource AccentBrush}"
                                                      SelectionBrush="{DynamicResource SelectionFillBrush}" FontSize="12"
                                                     VerticalAlignment="Center"
                                                     Text="{Binding ProcessesPage.SearchText, UpdateSourceTrigger=PropertyChanged, Delay=200}" />
                                        </Grid>
                                    </Border>
                                    <Border Grid.ColumnSpan="4" HorizontalAlignment="Center"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="7" VerticalAlignment="Center" Height="32" Width="260"
                                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                            Visibility="{Binding IsStartupAppsPage, Converter={StaticResource BoolToVisibility}}">
                                        <Grid Margin="10,0">
                                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource MutedBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBox Margin="20,0,0,0" Background="Transparent" BorderThickness="0"
                                                     Foreground="{DynamicResource TextBrush}"
                                                     CaretBrush="{DynamicResource AccentBrush}"
                                                      SelectionBrush="{DynamicResource SelectionFillBrush}" FontSize="12"
                                                     VerticalAlignment="Center"
                                                     Text="{Binding StartupAppsPage.SearchText, UpdateSourceTrigger=PropertyChanged, Delay=200}" />
                                        </Grid>
                                    </Border>
                                    <Border Grid.ColumnSpan="4" HorizontalAlignment="Center"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="7" VerticalAlignment="Center" Height="32" Width="260"
                                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                            Visibility="{Binding IsServicesPage, Converter={StaticResource BoolToVisibility}}">
                                        <Grid Margin="10,0">
                                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource MutedBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBox Margin="20,0,0,0" Background="Transparent" BorderThickness="0"
                                                     Foreground="{DynamicResource TextBrush}"
                                                     CaretBrush="{DynamicResource AccentBrush}"
                                                      SelectionBrush="{DynamicResource SelectionFillBrush}" FontSize="12"
                                                     VerticalAlignment="Center"
                                                     Text="{Binding ServicesPage.SearchText, UpdateSourceTrigger=PropertyChanged, Delay=200}" />
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                                                Margin="0,0,12,0" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                        <Button Width="88" Height="30" Padding="0" Margin="0,0,8,0"
                                                Style="{StaticResource TopBarActionButton}" FontSize="12"
                                                Command="{Binding RefreshCommand}" Content="立即刷新" />
                                        <Button Width="88" Height="30" Padding="0"
                                                Style="{StaticResource TopBarDangerButton}" FontSize="12"
                                                Command="{Binding ProcessesPage.KillSelectedProcessCommand}"
                                                Content="结束进程"
                                                Visibility="{Binding IsProcessesPage, Converter={StaticResource BoolToVisibility}}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Stretch"
                                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                        <Button Style="{StaticResource WinBtnStyle}" Click="MinimizeButton_Click">
                                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                        </Button>
                                        <Button Style="{StaticResource WinBtnStyle}" Click="MaximizeButton_Click">
                                            <TextBlock x:Name="MaximizeIcon" Text="&#xE923;"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                        </Button>
                                        <Button Style="{StaticResource CloseBtnStyle}" Click="CloseButton_Click">
                                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                                <ContentPresenter Grid.Row="1" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="WindowState" Value="Maximized">
                                <Setter TargetName="WindowBorder" Property="BorderThickness" Value="8" />
                                <Setter TargetName="MaximizeIcon" Property="Text" Value="&#xE923;" />
                            </Trigger>
                            <Trigger Property="WindowState" Value="Normal">
                                <Setter TargetName="MaximizeIcon" Property="Text" Value="&#xE922;" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Style>

    <Grid Margin="20,14,20,18"
          shell:WindowChrome.IsHitTestVisibleInChrome="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding NavigationColumnWidth}" /><ColumnDefinition Width="{Binding NavigationSpacerWidth}" /><ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="16" Padding="{Binding NavigationPanelPadding}"
                shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /><RowDefinition Height="20" /><RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="系统概览" Foreground="{DynamicResource TextBrush}" FontSize="18" FontWeight="SemiBold"
                               VerticalAlignment="Center" Visibility="{Binding NavigationHeaderVisibility}" />
                    <Button Grid.Column="1" Width="34" Height="34" Padding="0"
                            Background="{DynamicResource HoverBrush}" BorderThickness="0" Cursor="Hand"
                            Command="{Binding ToggleNavigationCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Root" Property="Opacity" Value="0.85" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Root" Property="Opacity" Value="0.7" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Foreground="{DynamicResource TextBrush}" FontSize="12"
                                   Text="&#xE76C;">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsNavigationCollapsed}" Value="True">
                                            <Setter Property="Text" Value="&#xE76B;" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </Grid>
                <StackPanel Grid.Row="2">
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Processes"
                            Style="{StaticResource NavButtonBase}" Margin="0,0,0,8"
                            ToolTip="进程管理">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Root" Background="Transparent" CornerRadius="14" Padding="14,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="6" /><ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="20" /><ColumnDefinition Width="14" /><ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="Marker" Background="{DynamicResource AccentBrush}"
                                                Width="4" Height="22" CornerRadius="3" Visibility="Collapsed" VerticalAlignment="Center" />
                                        <Border x:Name="MarkerGlow" Grid.Column="1" Width="1" Height="18" Background="{DynamicResource AccentGlowBrush}" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        <StackPanel x:Name="NavContent" Grid.Column="2" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock x:Name="NavIcon" Text="&#xE7F8;" FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{DynamicResource Muted2Brush}" VerticalAlignment="Center" FontSize="14"
                                                       Width="16" TextAlignment="Center" />
                                            <TextBlock Text="进程" Foreground="{DynamicResource TextBrush}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="14,0,0,0"
                                                       Visibility="{Binding DataContext.NavigationLabelVisibility, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding DataContext.IsNavigationCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter TargetName="NavContent" Property="Grid.Column" Value="0" />
                                        <Setter TargetName="NavContent" Property="Grid.ColumnSpan" Value="5" />
                                        <Setter TargetName="NavContent" Property="HorizontalAlignment" Value="Center" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsProcessesPage}" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                        <Setter TargetName="Marker" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="MarkerGlow" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Performance"
                            Style="{StaticResource NavButtonBase}" Margin="0,0,0,10"
                            ToolTip="性能监控">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Root" Background="Transparent" CornerRadius="14" Padding="14,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="6" /><ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="20" /><ColumnDefinition Width="14" /><ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="Marker" Background="{DynamicResource AccentBrush}"
                                                Width="4" Height="22" CornerRadius="3" Visibility="Collapsed" VerticalAlignment="Center" />
                                        <Border x:Name="MarkerGlow" Grid.Column="1" Width="1" Height="18" Background="{DynamicResource AccentGlowBrush}" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        <StackPanel x:Name="NavContent" Grid.Column="2" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock x:Name="NavIcon" Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{DynamicResource Muted2Brush}" VerticalAlignment="Center" FontSize="14"
                                                       Width="16" TextAlignment="Center" />
                                            <TextBlock Text="性能" Foreground="{DynamicResource TextBrush}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="14,0,0,0"
                                                       Visibility="{Binding DataContext.NavigationLabelVisibility, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding DataContext.IsNavigationCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter TargetName="NavContent" Property="Grid.Column" Value="0" />
                                        <Setter TargetName="NavContent" Property="Grid.ColumnSpan" Value="5" />
                                        <Setter TargetName="NavContent" Property="HorizontalAlignment" Value="Center" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsPerformancePage}" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                        <Setter TargetName="Marker" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="MarkerGlow" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="StartupApps"
                            Style="{StaticResource NavButtonBase}" Margin="0,0,0,10"
                            ToolTip="启动应用">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Root" Background="Transparent" CornerRadius="14" Padding="14,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="6" /><ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="20" /><ColumnDefinition Width="14" /><ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="Marker" Background="{DynamicResource AccentBrush}"
                                                Width="4" Height="22" CornerRadius="3" Visibility="Collapsed" VerticalAlignment="Center" />
                                        <Border x:Name="MarkerGlow" Grid.Column="1" Width="1" Height="18" Background="{DynamicResource AccentGlowBrush}" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        <StackPanel x:Name="NavContent" Grid.Column="2" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock x:Name="NavIcon" Text="&#xE7EF;" FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{DynamicResource Muted2Brush}" VerticalAlignment="Center" FontSize="14"
                                                       Width="16" TextAlignment="Center" />
                                            <TextBlock Text="启动应用" Foreground="{DynamicResource TextBrush}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="14,0,0,0"
                                                       Visibility="{Binding DataContext.NavigationLabelVisibility, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding DataContext.IsNavigationCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter TargetName="NavContent" Property="Grid.Column" Value="0" />
                                        <Setter TargetName="NavContent" Property="Grid.ColumnSpan" Value="5" />
                                        <Setter TargetName="NavContent" Property="HorizontalAlignment" Value="Center" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsStartupAppsPage}" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                        <Setter TargetName="Marker" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="MarkerGlow" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Services"
                            Style="{StaticResource NavButtonBase}"
                            ToolTip="服务管理">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Root" Background="Transparent" CornerRadius="14" Padding="14,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="6" /><ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="20" /><ColumnDefinition Width="14" /><ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="Marker" Background="{DynamicResource AccentBrush}"
                                                Width="4" Height="22" CornerRadius="3" Visibility="Collapsed" VerticalAlignment="Center" />
                                        <Border x:Name="MarkerGlow" Grid.Column="1" Width="1" Height="18" Background="{DynamicResource AccentGlowBrush}" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        <StackPanel x:Name="NavContent" Grid.Column="2" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock x:Name="NavIcon" Text="&#xE895;" FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{DynamicResource Muted2Brush}" VerticalAlignment="Center" FontSize="14"
                                                       Width="16" TextAlignment="Center" />
                                            <TextBlock Text="服务" Foreground="{DynamicResource TextBrush}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="14,0,0,0"
                                                       Visibility="{Binding DataContext.NavigationLabelVisibility, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding DataContext.IsNavigationCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter TargetName="NavContent" Property="Grid.Column" Value="0" />
                                        <Setter TargetName="NavContent" Property="Grid.ColumnSpan" Value="5" />
                                        <Setter TargetName="NavContent" Property="HorizontalAlignment" Value="Center" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsServicesPage}" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                        <Setter TargetName="Marker" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="MarkerGlow" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Settings"
                            Style="{StaticResource NavButtonBase}" Margin="0,10,0,0"
                            ToolTip="系统设置">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Root" Background="Transparent" CornerRadius="14" Padding="14,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="6" /><ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="20" /><ColumnDefinition Width="14" /><ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="Marker" Background="{DynamicResource AccentBrush}"
                                                Width="4" Height="22" CornerRadius="3" Visibility="Collapsed" VerticalAlignment="Center" />
                                        <Border x:Name="MarkerGlow" Grid.Column="1" Width="1" Height="18" Background="{DynamicResource AccentGlowBrush}" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        <StackPanel x:Name="NavContent" Grid.Column="2" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock x:Name="NavIcon" Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{DynamicResource Muted2Brush}" VerticalAlignment="Center" FontSize="14"
                                                       Width="16" TextAlignment="Center" />
                                            <TextBlock Text="设置" Foreground="{DynamicResource TextBrush}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="14,0,0,0"
                                                       Visibility="{Binding DataContext.NavigationLabelVisibility, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding DataContext.IsNavigationCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter TargetName="NavContent" Property="Grid.Column" Value="0" />
                                        <Setter TargetName="NavContent" Property="Grid.ColumnSpan" Value="5" />
                                        <Setter TargetName="NavContent" Property="HorizontalAlignment" Value="Center" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSettingsPage}" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                        <Setter TargetName="Marker" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="MarkerGlow" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="2"
              shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" /><RowDefinition Height="12" /><RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    Background="Transparent"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <ContentControl Content="{Binding CurrentPage}" />
            </Border>
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Foreground="{DynamicResource MutedBrush}" FontSize="12" VerticalAlignment="Center"
                           Text="{Binding StatusMessage}" />
            </Grid>
        </Grid>

        <Border Grid.ColumnSpan="3"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,12,8"
                Padding="16,10"
                Background="{DynamicResource SurfaceElevatedBrush}"
                BorderBrush="{DynamicResource BorderStrongBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Panel.ZIndex="99"
                Visibility="{Binding IsToastVisible, Converter={StaticResource BoolToVisibility}}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="6" Direction="270" Color="#000000" Opacity="0.16" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Border Width="22" Height="22"
                        Background="{Binding ToastBadgeBackground}"
                        BorderBrush="{Binding ToastBadgeBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="11"
                        Margin="0,0,8,0">
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                               Foreground="{Binding ToastAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="{Binding ToastMessage}" Foreground="{DynamicResource TextStrongBrush}" FontSize="12.5"
                           FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
