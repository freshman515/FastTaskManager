<UserControl x:Class="FastTaskManager.App.Views.PerformanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="18"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ 左侧面板：指标列表 ═══ -->
        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="14" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="性能" Foreground="{DynamicResource TextBrush}" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="参考任务管理器性能页，提供左侧设备列表和右侧趋势图。"
                               Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,6,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <ListBox Grid.Row="2" ItemsSource="{Binding PerformanceMetrics}"
                         SelectedItem="{Binding SelectedPerformanceMetric}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,10"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="SnapsToDevicePixels" Value="True"/>
                            <Setter Property="UseLayoutRounding" Value="True"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Root" Background="{DynamicResource PanelBrush}"
                                                 BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="12" Padding="0"
                                                ClipToBounds="True"
                                                SnapsToDevicePixels="True"
                                                UseLayoutRounding="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- 选中 Accent 指示条：始终绑定颜色，通过 Opacity 切换显隐 -->
                                                <Border x:Name="AccentBar"
                                                         Grid.Column="0"
                                                         Background="{Binding AccentBrush}"
                                                         CornerRadius="11,0,0,11"
                                                         Opacity="0"/>
                                                <ContentPresenter Grid.Column="1" Margin="12"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SelectedBrush}"/>
                                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                <Setter TargetName="AccentBar" Property="Opacity" Value="1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" Foreground="{Binding AccentBrush}"
                                               FontSize="17" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding ValueText}" Foreground="{DynamicResource TextBrush}"
                                               FontSize="24" FontWeight="Bold" Margin="0,6,0,0"/>
                                    <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource Muted2Brush}"
                                               FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding DetailText}" Foreground="{DynamicResource MutedBrush}"
                                               FontSize="11" Margin="0,8,0,0"/>
                                </StackPanel>
                                <!-- 迷你趋势图：加深色背景增强可读性 -->
                                <Border Grid.Column="1" Margin="10,0,0,0"
                                        Background="{DynamicResource PanelBrush}" CornerRadius="8">
                                    <Viewbox>
                                        <Canvas Width="640" Height="220">
                                            <Polygon Points="{Binding AreaPoints}" Fill="{Binding FillBrush}"/>
                                            <Polyline Points="{Binding ChartPoints}"
                                                      Stroke="{Binding AccentBrush}"
                                                      StrokeThickness="2" StrokeLineJoin="Round"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ═══ 右侧面板 ═══ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 顶部信息卡 -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="14" Padding="18,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedPerformanceMetric.Title}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="34" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SelectedPerformanceMetric.Subtitle}"
                                   Foreground="{DynamicResource Muted2Brush}"
                                   FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding SelectedPerformanceMetric.ValueText}"
                                   Foreground="{Binding SelectedPerformanceMetric.AccentBrush}"
                                   FontSize="32" FontWeight="Bold" HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding SelectedPerformanceMetric.DetailText}"
                                   Foreground="{DynamicResource MutedBrush}"
                                   FontSize="12" HorizontalAlignment="Right" Margin="0,6,0,0"/>
                        <!-- 实时徽章 -->
                        <Border Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="6,2"
                                HorizontalAlignment="Right" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6"
                                         Fill="{Binding SelectedPerformanceMetric.AccentBrush}"
                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="实时"
                                           Foreground="{Binding SelectedPerformanceMetric.AccentBrush}"
                                           FontSize="11" FontWeight="Medium"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 趋势图面板 -->
            <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="14" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 图表标题行 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="60 秒趋势"
                                       Foreground="{DynamicResource MutedBrush}"
                                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Border Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                     CornerRadius="4" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="实时采样"
                                           Foreground="{Binding SelectedPerformanceMetric.AccentBrush}"
                                           FontSize="10"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="0%" Foreground="{DynamicResource MutedBrush}"
                                       FontSize="11" Margin="0,0,12,0"/>
                            <TextBlock Text="100%" Foreground="{DynamicResource MutedBrush}" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <!-- 图表区（含 Y 轴标签叠加层） -->
                    <Border Grid.Row="2" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1" CornerRadius="12">
                        <Grid>
                            <!-- 数据图层：Margin 留出与边框的间距 -->
                            <Grid Margin="16">
                                <Viewbox Stretch="Fill">
                                    <Canvas Width="640" Height="220">
                                        <!-- Y 轴水平参考线：y=55(75%), y=110(50%), y=165(25%) -->
                                        <Line X1="0" Y1="55"  X2="640" Y2="55"  Stroke="{DynamicResource ChartGridBrush}" StrokeThickness="1"/>
                                        <Line X1="0" Y1="110" X2="640" Y2="110" Stroke="{DynamicResource ChartGridBrush}" StrokeThickness="1"/>
                                        <Line X1="0" Y1="165" X2="640" Y2="165" Stroke="{DynamicResource ChartGridBrush}" StrokeThickness="1"/>
                                        <!-- 基线 -->
                                        <Line X1="0" Y1="219" X2="640" Y2="219" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1"/>
                                        <!-- 面积填充 -->
                                         <Polygon Points="{Binding SelectedPerformanceMetric.AreaPoints}"
                                                  Fill="{Binding SelectedPerformanceMetric.FillBrush}"/>
                                         <!-- 折线 -->
                                         <Polyline Points="{Binding SelectedPerformanceMetric.ChartPoints}"
                                                   Stroke="{Binding SelectedPerformanceMetric.AccentBrush}"
                                                   StrokeThickness="2" StrokeLineJoin="Round"
                                                   StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Grid>
                            <!-- Y 轴百分比标签叠加：Margin 与 Viewbox 对齐，4 等分对应 4 段区间 -->
                            <Grid Margin="4,16,0,16" HorizontalAlignment="Left" Width="28">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1*"/>
                                    <RowDefinition Height="1*"/>
                                    <RowDefinition Height="1*"/>
                                    <RowDefinition Height="1*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="100" VerticalAlignment="Top"
                                           Foreground="{DynamicResource MutedBrush}" FontSize="9" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Row="1" Text="75" VerticalAlignment="Top"
                                           Foreground="{DynamicResource MutedBrush}" FontSize="9" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Row="2" Text="50" VerticalAlignment="Top"
                                           Foreground="{DynamicResource MutedBrush}" FontSize="9" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Row="3" Text="25" VerticalAlignment="Top"
                                           Foreground="{DynamicResource MutedBrush}" FontSize="9" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Row="3" Text="0" VerticalAlignment="Bottom"
                                           Foreground="{DynamicResource MutedBrush}" FontSize="9" HorizontalAlignment="Right"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- 时间轴标签 -->
                    <Grid Grid.Row="4">
                        <TextBlock Text="← 60 秒前" Foreground="{DynamicResource MutedBrush}"
                                   FontSize="10" HorizontalAlignment="Left"/>
                        <TextBlock Text="现在 →" Foreground="{DynamicResource MutedBrush}"
                                   FontSize="10" HorizontalAlignment="Right"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- 底部统计卡片：边框颜色随选中指标的 AccentBrush 变化 -->
            <UniformGrid Grid.Row="4" Columns="3">
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{Binding SelectedPerformanceMetric.AccentBrush}"
                        BorderThickness="1" CornerRadius="12" Padding="16,14" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedPerformanceMetric.PrimaryLabel}"
                                   Foreground="{DynamicResource MutedBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding SelectedPerformanceMetric.PrimaryValue}"
                                   Foreground="{DynamicResource TextBrush}" FontSize="22"
                                   FontWeight="SemiBold" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{Binding SelectedPerformanceMetric.AccentBrush}"
                        BorderThickness="1" CornerRadius="12" Padding="16,14" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedPerformanceMetric.SecondaryLabel}"
                                   Foreground="{DynamicResource MutedBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding SelectedPerformanceMetric.SecondaryValue}"
                                   Foreground="{DynamicResource TextBrush}" FontSize="22"
                                   FontWeight="SemiBold" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{Binding SelectedPerformanceMetric.AccentBrush}"
                        BorderThickness="1" CornerRadius="12" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedPerformanceMetric.TertiaryLabel}"
                                   Foreground="{DynamicResource MutedBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding SelectedPerformanceMetric.TertiaryValue}"
                                   Foreground="{DynamicResource TextBrush}" FontSize="22"
                                   FontWeight="SemiBold" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>
    </Grid>
</UserControl>
