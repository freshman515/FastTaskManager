<UserControl x:Class="FastTaskManager.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="SettingsOptionButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="Dot"
                                        Width="18"
                                        Height="18"
                                        CornerRadius="9"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource BorderStrongBrush}"
                                        BorderThickness="1.5"
                                        VerticalAlignment="Top">
                                    <Border x:Name="DotInner"
                                            Width="8"
                                            Height="8"
                                            CornerRadius="4"
                                            Background="{DynamicResource AccentBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed"/>
                                </Border>
                                <ContentPresenter Grid.Column="2"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Dot" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="DotInner" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Root"
                                Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="Box"
                                        Width="18"
                                        Height="18"
                                        CornerRadius="5"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource BorderStrongBrush}"
                                        BorderThickness="1.5"
                                        VerticalAlignment="Top">
                                    <TextBlock x:Name="CheckMark"
                                               Text="&#xE73E;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="10"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed"/>
                                </Border>
                                <ContentPresenter Grid.Column="2"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Box" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsFieldTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinWidth" Value="120"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="18,16">
                <StackPanel>
                    <TextBlock Text="设置" Foreground="{DynamicResource TextBrush}" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="统一管理启动方式和主题外观，修改后会立即保存。" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="18">
                <StackPanel>
                    <TextBlock Text="启动方式" Foreground="{DynamicResource TextBrush}" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="选择程序启动时默认进入的界面，并决定是否随 Windows 自动启动。" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,6,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <RadioButton Style="{StaticResource SettingsOptionButton}" IsChecked="{Binding IsMainWindowStartup, Mode=OneWay}" Checked="MainWindowStartup_Checked">
                            <StackPanel>
                                <TextBlock Text="主窗口启动" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="打开完整任务管理页面" Foreground="{DynamicResource Muted2Brush}" FontSize="12" Margin="0,6,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource SettingsOptionButton}" IsChecked="{Binding IsQuickLauncherStartup, Mode=OneWay}" Margin="0" Checked="QuickLauncherStartup_Checked">
                            <StackPanel>
                                <TextBlock Text="QuickLauncher 启动" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="仅显示 QuickLauncher，主窗口不自动显示" Foreground="{DynamicResource Muted2Brush}" FontSize="12" Margin="0,6,0,0"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                    <CheckBox Style="{StaticResource SettingsCheckBox}"
                              Content="开机自动启动 FastTaskManager"
                              Margin="0,16,0,0"
                              IsChecked="{Binding LaunchAtStartup}"/>
                    <Border Margin="0,16,0,0" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="{Binding StartupModeDescription}" Foreground="{DynamicResource Muted2Brush}" FontSize="12" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding LaunchAtStartupDescription}" Foreground="{DynamicResource Muted2Brush}" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="18">
                <StackPanel>
                    <TextBlock Text="主题外观" Foreground="{DynamicResource TextBrush}" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="切换浅色或深色主题，页面、弹窗和 QuickLauncher 会同步更新。" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,6,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <RadioButton Style="{StaticResource SettingsOptionButton}" IsChecked="{Binding IsDarkTheme, Mode=OneWay}" Checked="DarkTheme_Checked">
                            <StackPanel>
                                <TextBlock Text="深色主题" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="适合夜间和高对比内容浏览" Foreground="{DynamicResource Muted2Brush}" FontSize="12" Margin="0,6,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource SettingsOptionButton}" IsChecked="{Binding IsLightTheme, Mode=OneWay}" Margin="0" Checked="LightTheme_Checked">
                            <StackPanel>
                                <TextBlock Text="浅色主题" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="适合明亮环境和白底阅读" Foreground="{DynamicResource Muted2Brush}" FontSize="12" Margin="0,6,0,0"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                    <Border Margin="0,16,0,0" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14,12">
                        <TextBlock Text="{Binding ThemeDescription}" Foreground="{DynamicResource Muted2Brush}" FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="6" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="18">
                <StackPanel>
                    <TextBlock Text="启动窗口" Foreground="{DynamicResource TextBrush}" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="配置主窗口启动时的显示状态、位置和大小。" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,6,0,0"/>

                    <CheckBox Style="{StaticResource SettingsCheckBox}"
                              Content="启用自定义窗口位置和大小"
                              Margin="0,16,0,0"
                              IsChecked="{Binding UseCustomMainWindowPlacement}"/>

                    <CheckBox Style="{StaticResource SettingsCheckBox}"
                              Content="启动时默认最大化主窗口"
                              Margin="0,10,0,0"
                              IsChecked="{Binding MainWindowStartMaximized}"/>

                    <UniformGrid Columns="2" Margin="0,16,0,0">
                        <StackPanel Margin="0,0,12,12">
                            <TextBlock Text="左边距" Foreground="{DynamicResource Muted2Brush}" FontSize="12" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource SettingsFieldTextBox}"
                                     Text="{Binding MainWindowLeft, UpdateSourceTrigger=LostFocus}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="顶部边距" Foreground="{DynamicResource Muted2Brush}" FontSize="12" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource SettingsFieldTextBox}"
                                     Text="{Binding MainWindowTop, UpdateSourceTrigger=LostFocus}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="窗口宽度" Foreground="{DynamicResource Muted2Brush}" FontSize="12" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource SettingsFieldTextBox}"
                                     Text="{Binding MainWindowWidth, UpdateSourceTrigger=LostFocus}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="窗口高度" Foreground="{DynamicResource Muted2Brush}" FontSize="12" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource SettingsFieldTextBox}"
                                     Text="{Binding MainWindowHeight, UpdateSourceTrigger=LostFocus}"/>
                        </StackPanel>
                    </UniformGrid>

                    <DockPanel Margin="0,16,0,0">
                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding ResetMainWindowPlacementCommand}"
                                Content="恢复默认"/>
                        <TextBlock Foreground="{DynamicResource Muted2Brush}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Text="数值会在失去焦点后自动保存，宽高低于主窗口最小值时会自动修正。"/>
                    </DockPanel>

                    <Border Margin="0,16,0,0" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14,12">
                        <TextBlock Text="{Binding MainWindowPlacementDescription}" Foreground="{DynamicResource Muted2Brush}" FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
