<Window x:Class="FastTaskManager.App.QuickLauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Width="760"
        SizeToContent="Height"
        MaxHeight="620"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="True"
        FontFamily="Microsoft YaHei"
        KeyDown="Window_KeyDown"
        Deactivated="Window_Deactivated">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <Style x:Key="QuickLauncherIconButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource InputElevatedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Thumb" x:Key="ScrollThumbStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThBorder" Background="{DynamicResource BorderStrongBrush}" CornerRadius="4"
                                Margin="2,1" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThBorder" Property="Background"
                                        Value="{DynamicResource Muted2Brush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThBorder" Property="Background"
                                        Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Width" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root" Background="Transparent">
                            <Border x:Name="TrackBg" Background="{DynamicResource SurfaceBrush}" CornerRadius="4"
                                    Opacity="0" />
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Value="{TemplateBinding Value}"
                                   Minimum="{TemplateBinding Minimum}" Maximum="{TemplateBinding Maximum}"
                                   ViewportSize="{TemplateBinding ViewportSize}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"
                                                  IsTabStop="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumbStyle}" Cursor="Hand" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"
                                                  IsTabStop="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="8" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                            <Trigger SourceName="Root" Property="IsMouseOver" Value="True">
                                <Setter TargetName="TrackBg" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="0" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderStrongBrush}"
                BorderThickness="1" CornerRadius="12" Padding="18,12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="12" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasResults}" Value="True">
                            <Setter Property="CornerRadius" Value="12,12,0,0" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource Muted2Brush}"
                           FontSize="18" VerticalAlignment="Center" Margin="0,0,12,0" />
                <Grid Grid.Column="1" Margin="2,0,12,0">
                    <TextBox x:Name="SearchTextBox"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource TextStrongBrush}"
                             CaretBrush="{DynamicResource AccentBrush}"
                             FontSize="20"
                             VerticalContentAlignment="Center"
                             PreviewKeyDown="SearchTextBox_PreviewKeyDown"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=120}" />
                    <TextBlock Text="搜索进程、窗口，或输入 >kill chrome"
                               Foreground="{DynamicResource Muted2Brush}"
                               FontSize="19"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="SettingsButton"
                            Style="{StaticResource QuickLauncherIconButton}"
                            Width="34"
                            Height="34"
                            Margin="0,0,8,0"
                            Click="SettingsButton_Click"
                            ToolTip="打开设置">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   FontSize="14" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                    <Border Background="{DynamicResource InputElevatedBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10"
                            Padding="10,6">
                        <TextBlock Text="{Binding ModeHintText}" Foreground="{DynamicResource Muted2Brush}" FontSize="12"
                                   VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderStrongBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Margin="0,-1,0,0"
                Padding="8"
                Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibility}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="0,0,14,14" />
                    <Setter Property="Margin" Value="0,-1,0,0" />
                </Style>
            </Border.Style>
            <Grid Grid.Row="2">
                <ListBox x:Name="ResultsListBox"
                         ItemsSource="{Binding Results}"
                         SelectedItem="{Binding SelectedProcess}"
                         Background="Transparent"
                         BorderThickness="0"
                         MaxHeight="420"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ContextMenu>
                        <ContextMenu
                            DataContext="{Binding Path=PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="{Binding SelectedPrimaryActionText}" Command="{Binding ExecuteSelectedCommand}" />
                            <MenuItem Header="切换到窗口" Command="{Binding ActivateSelectedProcessCommand}" />
                            <Separator />
                            <MenuItem Header="结束进程" Command="{Binding KillProcessOnlyCommand}" />
                            <MenuItem Header="结束进程树" Command="{Binding KillSelectedProcessCommand}" />
                            <Separator />
                            <MenuItem Header="暂停进程" Command="{Binding SuspendProcessCommand}" />
                            <MenuItem Header="恢复进程" Command="{Binding ResumeProcessCommand}" />
                            <Separator />
                            <MenuItem Header="设置优先级">
                                <MenuItem Header="实时（RealTime）" Command="{Binding SetPriorityCommand}"
                                          CommandParameter="RealTime" />
                                <MenuItem Header="高（High）" Command="{Binding SetPriorityCommand}"
                                          CommandParameter="High" />
                                <MenuItem Header="高于正常" Command="{Binding SetPriorityCommand}"
                                          CommandParameter="AboveNormal" />
                                <MenuItem Header="正常（默认）" Command="{Binding SetPriorityCommand}"
                                          CommandParameter="Normal" />
                                <MenuItem Header="低于正常" Command="{Binding SetPriorityCommand}"
                                          CommandParameter="BelowNormal" />
                                <MenuItem Header="低（Idle）" Command="{Binding SetPriorityCommand}"
                                          CommandParameter="Idle" />
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="打开文件位置" Command="{Binding OpenFileLocationCommand}" />
                            <Separator />
                            <MenuItem Header="复制名称" Command="{Binding CopyNameCommand}" />
                            <MenuItem Header="复制 PID" Command="{Binding CopyPidCommand}" />
                            <MenuItem Header="复制路径" Command="{Binding CopyPathCommand}" />
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <EventSetter Event="PreviewMouseRightButtonDown" Handler="ResultItem_RightClickSelect" />
                            <EventSetter Event="MouseDoubleClick" Handler="ResultItem_DoubleClick" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,6" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Root" Background="Transparent" CornerRadius="12"
                                                Padding="14,12">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background"
                                                        Value="{DynamicResource HoverAltBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Root" Property="Background"
                                                        Value="{DynamicResource SelectedAltBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="92" />
                                </Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" Background="{DynamicResource PanelBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="10">
                                    <Image Source="{Binding Icon}" Width="18" Height="18"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{DynamicResource TextStrongBrush}" FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <Border Background="{DynamicResource SuccessBgBrush}"
                                                BorderBrush="{DynamicResource SuccessBorderBrush}"
                                                BorderThickness="1" CornerRadius="8" Padding="6,1" Margin="8,0,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding QuickBadgeText}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding QuickBadgeText}" Foreground="{DynamicResource SuccessBrush}"
                                                       FontSize="10" FontWeight="SemiBold" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding PathText}" Foreground="{DynamicResource MutedBrush}"
                                               FontSize="11" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock Grid.Column="3" Text="{Binding PidText}"
                                           Foreground="{DynamicResource Muted2Brush}" FontSize="12"
                                           VerticalAlignment="Center" Margin="12,0,18,0" />
                                <TextBlock Grid.Column="4" Text="{Binding CpuText}"
                                           Foreground="{Binding CpuTextBrush}" FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center" HorizontalAlignment="Right" />
                                <TextBlock Grid.Column="5" Text="{Binding MemoryText}"
                                           Foreground="{Binding MemoryTextBrush}" FontSize="12"
                                           FontWeight="SemiBold" VerticalAlignment="Center"
                                           HorizontalAlignment="Right" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </Grid>
        </Border>

        <Border Grid.RowSpan="3"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="0"
                Padding="14,9"
                Background="{DynamicResource SurfaceElevatedBrush}"
                BorderBrush="{DynamicResource BorderStrongBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Panel.ZIndex="99"
                Visibility="{Binding IsToastVisible, Converter={StaticResource BoolToVisibility}}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="5" Direction="270" Color="#000000" Opacity="0.16" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Border Width="22" Height="22"
                        Background="{Binding ToastBadgeBackground}"
                        BorderBrush="{Binding ToastBadgeBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="11"
                        Margin="0,0,8,0">
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                               Foreground="{Binding ToastAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="{Binding ToastMessage}" Foreground="{DynamicResource TextStrongBrush}" FontSize="12"
                           FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
